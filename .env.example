# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_OPENROUTER_API_KEY: Client-side OpenRouter key for the in-app Asesor IA panel.
# Uses model deepseek/deepseek-chat-v3-0324:free (free tier, no billing required).
# Get a key at openrouter.ai → Keys → Create Key.
# Must have VITE_ prefix to be exposed to browser code via import.meta.env.
VITE_OPENROUTER_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_CLIENT_ID: Optional Google Client ID for direct Google Calendar event integration.
# Created in Google Cloud Console Credentials -> OAuth 2.0 Client IDs.
VITE_GOOGLE_CLIENT_ID=""
